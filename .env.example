# Application
NODE_ENV=development
PORT=8000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/property_marketplace_dev?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/property_marketplace_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=replace-with-a-long-random-access-token-secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-token-secret
JWT_REFRESH_EXPIRATION=7d

# Paystack
PAYSTACK_SECRET_KEY=sk_test_replace_with_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_replace_with_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret-if-used

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@propertymarketplace.com

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Security
BCRYPT_SALT_ROUNDS=12
